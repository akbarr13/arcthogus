# Supabase — copy dari project settings
# Aman disimpan di server, tidak pernah ke browser
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — WAJIB server-only, jangan pernah expose ke client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Domain yang diizinkan untuk CORS (misal: https://arcthogus.arwebs.my.id)
ALLOWED_ORIGIN=https://yourdomain.com
